{
  "manifest_version": 3,
  "name": "MGT 3074 Worksheet Auto-Save",
  "version": "1.0.0",
  "description": "Auto-saves your MGT 3074 worksheet responses to local storage. Never lose your work again.",
  "content_scripts": [
    {
      "matches": ["*://thehokiespirit.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
